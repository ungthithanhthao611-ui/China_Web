lBfZHH2UnwY58KL8DAUhZv/view?usp=sharing","media_migration_status":"pending"},"sort_order":20,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","image":null}]},{"id":164,"entity_type":"page","entity_id":6,"language_id":2,"block_key":"intro_paragraphs","title":"Nội dung giới thiệu (Các đoạn văn)","subtitle":null,"content":null,"block_type":"rich_text_list","sort_order":50,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","items":[{"id":1841,"block_id":164,"item_key":"paragraph_1","title":"Page 2 Gioi thieu cong ty - Noi dung chi tiet / Van ban 1","title_en":"Page 2 Company introduction - Detailed content / Information 1","title_zh":"第2页 公司介绍 - 详细内容/信息1","subtitle":null,"subtitle_en":null,"subtitle_zh":null,"content":"CÔNG TY TNHH THƯƠNG MẠI QUỐC TẾ THIÊN ĐỒNG VIỆT NAM chuyên cung cấp các dòng đá mềm – tấm ốp linh hoạt cao cấp, ứng dụng trong trang trí nội thất và ngoại thất hiện đại.","content_en":"THIEN DONG VIETNAM INTERNATIONAL TRADING COMPANY LIMITED specializes in providing soft stone lines - high-quality flexible panels, applied in modern interior and exterior decoration.","content_zh":"天东越南国际贸易有限公司专业提供软石线条——高品质柔性面板，应用于现代室内外装饰。","link":null,"image_id":null,"metadata_json":null,"sort_order":10,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-05-01T11:57:54.111511Z","image":null},{"id":1842,"block_id":164,"item_key":"paragraph_2","title":"Page 2 Gioi thieu cong ty - Noi dung chi tiet / Van ban 2","title_en":"Page 2 Company introduction - Detailed content / Notice 2","title_zh":"第2页 公司介绍-详细内容/公告2","subtitle":null,"subtitle_en":null,"subtitle_zh":null,"content":"Sản phẩm của chúng tôi mang lại giải pháp thay thế hoàn hảo cho đá tự nhiên truyền thống với ưu điểm nhẹ, linh hoạt, dễ thi công và tiết kiệm chi phí, phù hợp cho nhiều loại công trình từ nhà ở, showroom đến dự án thương mại.","content_en":"Our products provide a perfect alternative to traditional natural stone with the advantages of being lightweight, flexible, easy to construct and cost-effective, suitable for many types of projects from houses, showrooms to commercial projects.","content_zh":"我们的产品提供了传统天然石材的完美替代品，具有轻质、灵活、易于施工和成本效益的优点，适用于从住宅、陈列室到商业项目的多种类型的项目。","link":null,"image_id":null,"metadata_json":null,"sort_order":20,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-05-01T11:58:01.104509Z","image":null}]},{"id":165,"entity_type":"page","entity_id":6,"language_id":2,"block_key":"speech_profile","title":"Tầm Nhìn & Sứ Mệnh","subtitle":null,"content":null,"block_type":"media","sort_order":60,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","items":[{"id":1843,"block_id":165,"item_key":"portrait","title":"Hình ảnh Giám đốc","title_en":null,"title_zh":null,"subtitle":null,"subtitle_en":null,"subtitle_zh":null,"content":null,"content_en":null,"content_zh":null,"link":null,"image_id":null,"metadata_json":{"src":"https://res.cloudinary.com/db1b15yn4/image/upload/v1776694034/Image_20260418142413_9_3_m65uzj.jpg"},"sort_order":10,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","image":null}]},{"id":166,"entity_type":"page","entity_id":6,"language_id":2,"block_key":"speech_body","title":"Tầm Nhìn & Sứ Mệnh","subtitle":null,"content":null,"block_type":"rich_text_list","sort_order":70,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","items":[{"id":1844,"block_id":166,"item_key":"vision","title":"Tầm nhìn","title_en":"Vision","title_zh":"想象","subtitle":null,"subtitle_en":null,"subtitle_zh":null,"content":"Trở thành đơn vị tiên phong tại Việt Nam trong lĩnh vực cung cấp vật liệu trang trí linh hoạt, đặc biệt là đá mềm, hướng đến thị trường quốc tế.","content_en":"Becoming a pioneer in Vietnam in the field of providing flexible decorative materials, especially soft stone, targeting the international market.","content_zh":"成为越南提供柔性装饰材料（尤其是软石材）领域的先驱，瞄准国际市场。","link":null,"image_id":null,"metadata_json":null,"sort_order":10,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-05-01T11:59:11.573674Z","image":null},{"id":1845,"block_id":166,"item_key":"mission","title":"Sứ mệnh","title_en":"Mission","title_zh":"使命","subtitle":null,"subtitle_en":null,"subtitle_zh":null,"content":"Mang đến giải pháp vật liệu ốp lát hiện đại, bền đẹp và tối ưu chi phí, giúp khách hàng nâng tầm không gian sống và công trình xây dựng.","content_en":"Providing modern, durable and cost-optimized tiling material solutions, helping customers enhance their living spaces and construction projects.","content_zh":"提供现代、耐用且成本优化的瓷砖材料解决方案，帮助客户改善他们的生活空间和建筑项目。","link":null,"image_id":null,"metadata_json":null,"sort_order":20,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-05-01T11:59:17.774116Z","image":null}]},{"id":167,"entity_type":"page","entity_id":6,"language_id":2,"block_key":"speech_signature","title":"Chairman Signature","subtitle":null,"content":null,"block_type":"key_value","sort_order":80,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","items":[{"id":1846,"block_id":167,"item_key":"sign_title","title":"","title_en":null,"title_zh":null,"subtitle":null,"subtitle_en":null,"subtitle_zh":null,"content":null,"content_en":null,"content_zh":null,"link":null,"image_id":null,"metadata_json":null,"sort_order":10,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","image":null},{"id":1847,"block_id":167,"item_key":"sign_name","title":"","title_en":null,"title_zh":null,"subtitle":null,"subtitle_en":null,"subtitle_zh":null,"content":null,"content_en":null,"content_zh":null,"link":null,"image_id":null,"metadata_json":null,"sort_order":20,"created_at":"2026-04-29T04:06:57.547570Z","updated_at":"2026-04-29T04:06:57.547570Z","image":null}]},{"id":168,"entity_type":"page","entity_id":6,"language_id":2,"block_key":"org_chart_image","title":"Sơ Đồ Tổ Chức","subtitle":null,"content":null,